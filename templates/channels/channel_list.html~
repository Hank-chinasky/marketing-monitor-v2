{% extends "base.html" %}

{% block content %}
<h1>Channels</h1>

<ul>
    {% for channel in channels %}
        <li style="margin-bottom: 1rem; padding: 1rem; border: 1px solid #ccc; background: #fafafa;">
            <div style="margin-bottom: 0.5rem;">
                <strong>{{ channel.creator.display_name }}</strong>
            </div>

            <div style="margin-bottom: 0.5rem;">
                {{ channel.platform|title }} / {{ channel.handle }} — {{ channel.status }}
            </div>

            <div style="margin-bottom: 0.5rem;">
                {% if channel.profile_url %}
                    <a href="{{ channel.profile_url }}" target="_blank">Open platform</a>
                {% else %}
                    <span>Geen profiel-URL</span>
                {% endif %}
            </div>

            <div style="display: flex; gap: 2rem; flex-wrap: wrap;">
                <div style="min-width: 260px; flex: 1;">
                    <strong>Account Access</strong>
                    <ul>
                        <li>Access mode: {{ channel.access_mode }}</li>
                        <li>Credential status: {{ channel.credential_status|default:"-" }}</li>
                        <li>2FA: {{ channel.two_factor_enabled|yesno:"Ja,Nee" }}</li>
                        <li>Last access check: {{ channel.last_access_check_at|default:"-" }}</li>
                    </ul>
                </div>

                <div style="min-width: 260px; flex: 1;">
                    <strong>Access Policy</strong>
                    <ul>
                        <li>VPN required: {{ channel.vpn_required|yesno:"Ja,Nee" }}</li>
                        <li>Approved region: {{ channel.approved_access_region|default:"-" }}</li>
                        <li>IP label: {{ channel.approved_ip_label|default:"-" }}</li>
                        <li>Egress IP: {{ channel.approved_egress_ip|default:"-" }}</li>
                        <li>Last IP check: {{ channel.last_ip_check_at|default:"-" }}</li>
                    </ul>
                </div>
            </div>
        </li>
    {% empty %}
        <li>Geen channels.</li>
    {% endfor %}
</ul>
{% endblock %}