<!doctype html>
<html lang="nl">
<head>
    <meta charset="utf-8">
    <title>Marketing Monitor</title>
</head>
<body>
    <nav>
	<a href="{% url 'creator-list' %}">Creators</a> |
	<a href="{% url 'channel-list' %}">Channels</a> |
	<a href="{% url 'assignment-list' %}">Assignments</a> |
	{% if request.user.is_authenticated %}
	    <form method="post" action="{% url 'logout' %}" style="display:inline;">
        {% csrf_token %}
            <button type="submit">Logout</button>
	   	 </form>
	{% else %}
	   	 <a href="{% url 'login' %}">Login</a>
	{% endif %}	
    </nav>
    <hr>
    {% block content %}{% endblock %}
</body>
</html>
