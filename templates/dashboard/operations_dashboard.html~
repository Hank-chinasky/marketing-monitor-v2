{% extends "base.html" %}

{% block content %}
<h1>Operations Dashboard</h1>

<div style="display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 1.5rem;">
    <div style="border: 1px solid #ccc; padding: 0.75rem; min-width: 180px;">
        <strong>Creators</strong><br>
        {{ summary.creator_count }}
    </div>
    <div style="border: 1px solid #ccc; padding: 0.75rem; min-width: 180px;">
        <strong>Channels</strong><br>
        {{ summary.channel_count }}
    </div>
    <div style="border: 1px solid #ccc; padding: 0.75rem; min-width: 180px;">
        <strong>Assignments</strong><br>
        {{ summary.assignment_count }}
    </div>
    <div style="border: 1px solid #ccc; padding: 0.75rem; min-width: 180px; background: #fee2e2;">
        <strong>Needs reset</strong><br>
        {{ summary.needs_reset_count }}
    </div>
    <div style="border: 1px solid #ccc; padding: 0.75rem; min-width: 180px; background: #fef3c7;">
        <strong>Geen 2FA</strong><br>
        {{ summary.without_2fa_count }}
    </div>
    <div style="border: 1px solid #ccc; padding: 0.75rem; min-width: 180px; background: #fef3c7;">
        <strong>VPN/IP gaps</strong><br>
        {{ summary.vpn_gap_count }}
    </div>
</div>

<h2>Aandacht vereist</h2>

<div style="display: flex; gap: 1.5rem; flex-wrap: wrap;">
    <div style="flex: 1; min-width: 320px;">
        <h3>Channels met credential reset nodig</h3>
        <ul>
            {% for channel in channels_needing_reset %}
                <li>
                    <a href="{% url 'creator-detail' channel.creator.pk %}">{{ channel.creator.display_name }}</a>
                    — {{ channel.platform }} / {{ channel.handle }}
                    {% if channel.profile_url %}
                        — <a href="{{ channel.profile_url }}" target="_blank">Open platform</a>
                    {% endif %}
                </li>
            {% empty %}
                <li>Geen directe reset issues.</li>
            {% endfor %}
        </ul>
    </div>

    <div style="flex: 1; min-width: 320px;">
        <h3>Channels zonder 2FA</h3>
        <ul>
            {% for channel in channels_without_2fa %}
                <li>
                    <a href="{% url 'creator-detail' channel.creator.pk %}">{{ channel.creator.display_name }}</a>
                    — {{ channel.platform }} / {{ channel.handle }}
                </li>
            {% empty %}
                <li>Geen 2FA issues.</li>
            {% endfor %}
        </ul>
    </div>

    <div style="flex: 1; min-width: 320px;">
        <h3>VPN/IP policy mist info</h3>
        <ul>
            {% for channel in vpn_policy_gaps %}
                <li>
                    <a href="{% url 'creator-detail' channel.creator.pk %}">{{ channel.creator.display_name }}</a>
                    — {{ channel.platform }} / {{ channel.handle }}
                </li>
            {% empty %}
                <li>Geen VPN/IP gaps.</li>
            {% endfor %}
        </ul>
    </div>

    <div style="flex: 1; min-width: 320px;">
        <h3>Consent issues</h3>
        <ul>
            {% for creator in creators_with_consent_issue %}
                <li>
                    <a href="{% url 'creator-detail' creator.pk %}">{{ creator.display_name }}</a>
                    — consent: {{ creator.consent_status }}
                </li>
            {% empty %}
                <li>Geen consent issues.</li>
            {% endfor %}
        </ul>
    </div>
</div>

<h2>Quick access</h2>
<ul>
    {% for channel in quick_channels %}
        <li>
            <strong>{{ channel.creator.display_name }}</strong>
            — {{ channel.platform }} / {{ channel.handle }}
            — VPN: {{ channel.vpn_required|yesno:"Ja,Nee" }}
            — Region: {{ channel.approved_access_region|default:"-" }}
            {% if channel.profile_url %}
                — <a href="{{ channel.profile_url }}" target="_blank">Open platform</a>
            {% endif %}
            — <a href="{% url 'creator-detail' channel.creator.pk %}">Creator detail</a>
            — <a href="{% url 'creator-network' channel.creator.pk %}">Netwerk</a>
        </li>
    {% empty %}
        <li>Geen channels beschikbaar.</li>
    {% endfor %}
</ul>

<h2>Mijn creators</h2>
<ul>
    {% for creator in creators %}
        <li>
            <a href="{% url 'creator-detail' creator.pk %}">{{ creator.display_name }}</a>
            — {{ creator.status }} / {{ creator.consent_status }}
            — <a href="{% url 'creator-network' creator.pk %}">Netwerk</a>
        </li>
    {% empty %}
        <li>Geen creators zichtbaar.</li>
    {% endfor %}
</ul>
{% endblock %}