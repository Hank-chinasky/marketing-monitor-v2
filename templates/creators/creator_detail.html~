{% extends "base.html" %}

{% block content %}
<h1>{{ creator.display_name }}</h1>

<div style="margin-bottom: 1rem;">
    <a class="quick-link" href="{% url 'creator-network' creator.pk %}">Bekijk netwerkkaart</a>
    {% if request.user.is_staff or request.user.is_superuser %}
        <a class="quick-link" href="{% url 'creator-update' creator.pk %}">Edit creator</a>
    {% endif %}
</div>

<div class="cards">
    <div class="card">
        <div>Status</div>
        <div style="margin-top:0.35rem;">
            {% if creator.status == "active" %}
                <span class="badge badge-green">active</span>
            {% else %}
                <span class="badge badge-yellow">{{ creator.status }}</span>
            {% endif %}
        </div>
    </div>

    <div class="card">
        <div>Consent</div>
        <div style="margin-top:0.35rem;">
            {% if creator.consent_status == "active" %}
                <span class="badge badge-green">consent ok</span>
            {% else %}
                <span class="badge badge-yellow">{{ creator.consent_status }}</span>
            {% endif %}
        </div>
    </div>

    <div class="card">
        <div>Channels</div>
        <div class="card-number">{{ summary.channel_count }}</div>
    </div>

    <div class="card">
        <div>Assignments</div>
        <div class="card-number">{{ summary.assignment_count }}</div>
    </div>

    <div class="card" style="background:#fff7ed;">
        <div>Needs reset</div>
        <div class="card-number">{{ summary.needs_reset_count }}</div>
    </div>

    <div class="card" style="background:#fffbeb;">
        <div>Geen 2FA</div>
        <div class="card-number">{{ summary.without_2fa_count }}</div>
    </div>

    <div class="card" style="background:#eff6ff;">
        <div>VPN vereist</div>
        <div class="card-number">{{ summary.vpn_required_count }}</div>
    </div>
</div>

<div class="grid">
    <div class="panel">
        <h3>Creator info</h3>
        <ul class="clean">
            <li><strong>Legal name:</strong> {{ creator.legal_name|default:"-" }}</li>
            <li><strong>Primary operator:</strong> {{ creator.primary_operator|default:"-" }}</li>
        </ul>
    </div>

    <div class="panel">
        <h3>Alerts</h3>
        <ul class="clean">
            {% if summary.needs_reset_count %}
                <li><span class="badge badge-red">needs reset</span> {{ summary.needs_reset_count }} channel(s)</li>
            {% endif %}
            {% if summary.without_2fa_count %}
                <li><span class="badge badge-yellow">geen 2FA</span> {{ summary.without_2fa_count }} channel(s)</li>
            {% endif %}
            {% if summary.vpn_required_count %}
                <li><span class="badge badge-blue">VPN verplicht</span> {{ summary.vpn_required_count }} channel(s)</li>
            {% endif %}
            {% if summary.policy_gap_count %}
                <li><span class="badge badge-yellow">policy gap</span> {{ summary.policy_gap_count }} channel(s)</li>
            {% endif %}
            {% if not summary.needs_reset_count and not summary.without_2fa_count and not summary.vpn_required_count and not summary.policy_gap_count %}
                <li>Geen directe alerts.</li>
            {% endif %}
        </ul>
    </div>
</div>

<h2>Notes</h2>
<div class="panel">
    {{ creator.notes|default:"Geen notities."|linebreaksbr }}
</div>

<h2>Channels</h2>
{% for channel in channels %}
    <div class="panel" style="margin-bottom: 1rem;">
        <div style="display:flex; justify-content:space-between; gap:1rem; flex-wrap:wrap; margin-bottom:0.75rem;">
            <div>
                <strong>{{ channel.platform|title }}</strong> / {{ channel.handle }}

                {% if channel.status == "active" %}
                    <span class="badge badge-green">active</span>
                {% else %}
                    <span class="badge badge-yellow">{{ channel.status }}</span>
                {% endif %}

                {% if channel.credential_status == "needs_reset" %}
                    <span class="badge badge-red">needs reset</span>
                {% endif %}

                {% if not channel.two_factor_enabled %}
                    <span class="badge badge-yellow">geen 2FA</span>
                {% else %}
                    <span class="badge badge-green">2FA ok</span>
                {% endif %}

                {% if channel.vpn_required %}
                    <span class="badge badge-blue">VPN verplicht</span>
                {% endif %}

                {% if channel.vpn_required and not channel.approved_ip_label and not channel.approved_egress_ip %}
                    <span class="badge badge-yellow">policy gap</span>
                {% endif %}
            </div>

            <div>
                {% if channel.profile_url %}
                    <a class="quick-link" href="{{ channel.profile_url }}" target="_blank">Open platform</a>
                {% endif %}
                <a class="quick-link" href="{% url 'channel-detail' channel.pk %}">Channel detail</a>
                <a class="quick-link" href="{% url 'creator-network' creator.pk %}">Netwerk</a>
                {% if request.user.is_staff or request.user.is_superuser %}
                    <a class="quick-link" href="{% url 'channel-update' channel.pk %}">Edit channel</a>
                {% endif %}
            </div>
        </div>

        <div class="grid">
            <div>
                <h3>Account Access</h3>
                <ul class="clean">
                    <li><strong>Profile URL:</strong>
                        {% if channel.profile_url %}
                            <a href="{{ channel.profile_url }}" target="_blank">{{ channel.profile_url }}</a>
                        {% else %}
                            -
                        {% endif %}
                    </li>
                    <li><strong>Access mode:</strong> {{ channel.access_mode }}</li>
                    <li><strong>Recovery owner:</strong> {{ channel.recovery_owner }}</li>
                    <li><strong>Login identifier:</strong> {{ channel.login_identifier|default:"-" }}</li>
                    <li><strong>Credential status:</strong> {{ channel.credential_status|default:"-" }}</li>
                    <li><strong>2FA enabled:</strong> {{ channel.two_factor_enabled|yesno:"Ja,Nee" }}</li>
                    <li><strong>Last access check:</strong> {{ channel.last_access_check_at|default:"-" }}</li>
                    <li><strong>Access notes:</strong> {{ channel.access_notes|default:"-"|linebreaksbr }}</li>
                </ul>
            </div>

            <div>
                <h3>Access Policy</h3>
                <ul class="clean">
                    <li><strong>VPN required:</strong> {{ channel.vpn_required|yesno:"Ja,Nee" }}</li>
                    <li><strong>Approved region:</strong> {{ channel.approved_access_region|default:"-" }}</li>
                    <li><strong>IP label:</strong> {{ channel.approved_ip_label|default:"-" }}</li>
                    <li><strong>Egress IP:</strong> {{ channel.approved_egress_ip|default:"-" }}</li>
                    <li><strong>Last IP check:</strong> {{ channel.last_ip_check_at|default:"-" }}</li>
                    <li><strong>Notes:</strong> {{ channel.access_profile_notes|default:"-"|linebreaksbr }}</li>
                </ul>
            </div>
        </div>
    </div>
{% empty %}
    <div class="panel">Geen channels.</div>
{% endfor %}

<h2>Assignments</h2>
<div class="panel">
    <ul class="clean">
        {% for assignment in assignments %}
            <li>
                <strong>{{ assignment.operator }}</strong>
                — {{ assignment.scope }}
                — {{ assignment.starts_at }} t/m {{ assignment.ends_at|default:"open" }}
            </li>
        {% empty %}
            <li>Geen assignments.</li>
        {% endfor %}
    </ul>
</div>
{% endblock %}